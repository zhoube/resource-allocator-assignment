# Copy this file to .env and fill in your real values locally.

OPENAI_API_KEY=your_openai_api_key_here
HEALTH_SCHEDULER_OPENAI_MODEL=gpt-5.4
HEALTH_SCHEDULER_OPENAI_BASE_URL=https://api.openai.com/v1
HEALTH_SCHEDULER_OPENAI_REASONING_EFFORT=medium
HEALTH_SCHEDULER_OPENAI_TIMEOUT_SECONDS=300
HEALTH_SCHEDULER_OPENAI_TIMEOUT_RETRY_REASONING_EFFORT=low
